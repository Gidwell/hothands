{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "hot-hands-api-worker",
  "main": "src/index.ts",
  "compatibility_date": "2026-05-13",
  "durable_objects": {
    "bindings": [
      {
        "name": "TABLE_ROOM",
        "class_name": "TableRoom"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["TableRoom"]
    }
  ],
  "observability": {
    "enabled": true
  }
}
